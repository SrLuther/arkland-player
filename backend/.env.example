# Copie este arquivo para .env e preencha os valores

# Banco de dados MySQL
# Formato: mysql+pymysql://usuario:senha@host:porta/banco
DATABASE_URL=mysql+pymysql://arkland:senha@localhost:3306/arkland_player

# Chave secreta para assinar os JWTs (gere com: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=troque-por-uma-chave-secreta-forte

# Chave de API do servidor ARK (compartilhada entre o plugin e o backend)
# O plugin usa essa chave no header X-Server-Key para autenticar uploads/downloads
SERVER_API_KEY=troque-por-uma-chave-de-servidor-forte

# Chave da API Steam Web (obtenha em https://steamcommunity.com/dev/apikey)
STEAM_API_KEY=sua-steam-api-key-aqui

# URL de retorno do Steam OpenID — deve ser a URL pública do seu backend + /auth/steam/callback
STEAM_OPENID_RETURN_URL=http://seuservidor.com:5000/auth/steam/callback

# Origens CORS permitidas (separadas por vírgula)
# Para desenvolvimento local:
CORS_ORIGINS=["http://localhost", "http://127.0.0.1"]
